+@given(spec_set=specifier_sets(vary_prereleases=True))
+@SETTINGS
+def test_idempotence_under_each_policy(spec_set: SpecifierSet) -> None:
+    """``r & r == r`` and ``r | r == r`` for every configured policy."""
+    r = spec_set.to_range()
+    assert r & r == r
+    assert r | r == r
