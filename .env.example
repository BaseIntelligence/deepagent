# Teacher / panel LLM configuration (copy to .env and fill in real values).
# The new forge pipeline reads ALL LLM endpoint config from these env vars.
# No specific provider is hardcoded in source; point these at any OpenAI- or
# Anthropic-compatible endpoint (e.g. an aggregator base URL).

# --- Teacher model (used to author bugs, specs, tests, alt-correct solutions) ---
# Model string is provider-prefixed for the routing library, e.g.:
#   anthropic/<model>   -> Anthropic-compatible endpoint at TEACHER_LLM_BASE_URL/v1/messages
#   openai/<model>      -> OpenAI-compatible endpoint at TEACHER_LLM_BASE_URL/v1
TEACHER_LLM_BASE_URL=https://your-endpoint.example
TEACHER_LLM_API_KEY=sk-your-key-here
TEACHER_LLM_MODEL=anthropic/your-teacher-model
TEACHER_LLM_PROVIDER=anthropic

# --- Calibration panel ---
# The panel reuses the same base_url + key by default; the set of solver models
# is configured per run (see forge panel config). Optionally override per-tier:
# PANEL_LLM_BASE_URL=
# PANEL_LLM_API_KEY=
